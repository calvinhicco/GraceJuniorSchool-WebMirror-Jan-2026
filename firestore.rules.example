rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /students/{docId} { allow read: if true; allow write: if false; }
    match /expenses/{docId} { allow read: if true; allow write: if false; }
    match /extraBilling/{docId} { allow read: if true; allow write: if false; }
    match /settings/{docId} { allow read: if true; allow write: if false; }
    match /outstandingStudents/{docId} { allow read: if true; allow write: if false; }
    match /inventories/{docId} { allow read: if true; allow write: if false; }
    match /sales/{docId} { allow read: if true; allow write: if false; }
    match /salesUsers/{docId} { allow read: if true; allow write: if false; }
    match /aiReports/{docId} { allow read: if true; allow write: if false; }
    match /academicStudentReports/{docId} { allow read: if true; allow write: if false; }
    match /academicStudentSubjectResults/{docId} { allow read: if true; allow write: if false; }
    match /academicReportCollections/{docId} { allow read: if true; allow write: if false; }
    match /academicSchoolBranding/{docId} { allow read: if true; allow write: if false; }
    match /academicReportSubjects/{docId} { allow read: if true; allow write: if false; }
    match /academicReportTeachers/{docId} { allow read: if true; allow write: if false; }
    match /academicTeacherBranding/{docId} { allow read: if true; allow write: if false; }
    match /appBackups/{docId} { allow read: if false; allow write: if false; }
    match /appBackupChunks/{docId} { allow read: if false; allow write: if false; }
  }
}
